#!/usr/bin/env bash
set -euo pipefail

# Minimize a Debian or Ubuntu cloud image to a provider-agnostic baseline. Removes AWS, Azure, GCP, IBM Cloud,
# Oracle Cloud, Rackspace, DigitalOcean, Linode, Vultr, Equinix Metal, OVHcloud, Hetzner, Ionos, Scaleway,
# Yandex Cloud, UpCloud, Exoscale, Leaseweb, Selectel, Gcore, Civo, Cherry Servers, Alibaba Cloud, Huawei Cloud,
# Tencent Cloud, Baidu Cloud, and Naver Cloud specific packages, repos, configs, and services, then strips
# everything not in the whitelist.

test "${EUID}" -eq 0 || { echo "Error: must run as root" >&2; exit 1; }
test -f /etc/os-release && . /etc/os-release || { echo "Error: /etc/os-release not found" >&2; exit 1; }
[[ "${ID:-}" =~ ^(debian|ubuntu)$ ]] || { echo "Error: unsupported distro '${ID:-unknown}'" >&2; exit 1; }
export DEBIAN_FRONTEND=noninteractive # all apt-get operations will use this from this point forward

_main() {
    _apt_sources
    _apt_update
    _apt_coreutils
    _apt_upgrade_kernel
    _apt_install_packages
    _apt_purge_packages
    _apt_reconfigure

    _configure_system
    _prune_users_and_groups
    _clean_system_files
    _clean_provider_files
    _ssh_access
    _upgrade_system
}

_required_packages=(
    # Init, system, package management
    systemd systemd-sysv dbus udev dpkg apt dialog
    # Base system
    base-files base-passwd bash coreutils debianutils diffutils findutils
    sudo grep gzip zstd login passwd sed tar util-linux less locales
    # Networking & DHCP
    iproute2 netbase ca-certificates curl iputils-ping
    # SSH & cloud-init
    openssh-server openssh-client cloud-init
)
_allowed_packages=(
    # Kernel & boot
    amd64-microcode intel-microcode # only needed on bare metal; removing these also drops linux-firmware
    grub-pc grub-efi-amd64 grub-efi-arm64 grub-efi-ia32 grub-ieee1275
    grub-efi-amd64-signed grub-efi-arm64-signed initramfs-tools
    # Networking & DHCP (provider-dependent)
    dhcpcd-base dhcpcd5 ifupdown netplan.io systemd-resolved
    # Coreutils provider (Ubuntu 25.10+)
    coreutils-from-gnu
)
_reconfigure_packages=( openssh-server libpam-runtime apt bash ca-certificates )
_reconfigure_files=( '/etc/apt/apt.conf.d/*' /etc/skel/.bashrc /etc/ssh/sshd_config )
_purge_packages=()

_apt_sources() {
    rm -rf /etc/apt/{sources.list,sources.list~,sources.list.d/*,mirrors,preferences.d/*} \
           /var/lib/apt/{lists/*,periodic/*,cdroms.list*,daily_lock}

    _repo_uri="http://deb.debian.org/debian";              test "${ID}" = "ubuntu" && _repo_uri="http://archive.ubuntu.com/ubuntu"
    _security_uri="http://deb.debian.org/debian-security"; test "${ID}" = "ubuntu" && _security_uri="http://security.ubuntu.com/ubuntu"
    _components="main";                                    test "${ID}" = "ubuntu" && _components="main restricted universe"

    cat > "/etc/apt/sources.list.d/${ID}.sources" <<EOF
Types: deb
URIs: ${_repo_uri}
Suites: ${VERSION_CODENAME} ${VERSION_CODENAME}-updates
Components: ${_components}
Signed-By: /usr/share/keyrings/${ID}-archive-keyring.gpg

Types: deb
URIs: ${_security_uri}
Suites: ${VERSION_CODENAME}-security
Components: ${_components}
Signed-By: /usr/share/keyrings/${ID}-archive-keyring.gpg
EOF
}
_apt_update() {
    apt-get update -o Acquire::PDiffs=false -o Acquire::Languages=none
}
_apt_coreutils() {
    dpkg -l coreutils-from-uutils 2>/dev/null | grep -q '^ii' || return 0

    # Swap to GNU coreutils if the Rust-based coreutils is installed (Ubuntu 25.10+)
    _purge_packages+=(coreutils-from-uutils rust-coreutils)
    _required_packages+=(coreutils-from-gnu)
}
_apt_upgrade_kernel() {
    # Select proper kernel metapackage: cloud/virtual for VMs, generic for bare metal
    _cpu_architecture="$(dpkg --print-architecture)"

    _virt_kernel=linux-image-virtual; test "${ID}" = "debian" && _virt_kernel="linux-image-cloud-${_cpu_architecture}"
    _bare_kernel=linux-image-generic; test "${ID}" = "debian" && _bare_kernel="linux-image-${_cpu_architecture}"
    _new_kernel_meta_package="$(systemd-detect-virt --vm -q && echo "${_virt_kernel}" || echo "${_bare_kernel}")"
    _old_kernel_meta_package="$(systemd-detect-virt --vm -q && echo "${_bare_kernel}" || echo "${_virt_kernel}")"

    _required_packages+=("${_new_kernel_meta_package}")
    apt-get install -y "${_new_kernel_meta_package}"
    # TODO: if Debian 13 doesn't boot into the new cloud kernel after reboot, GRUB may need to be regenerated manually: grub-mkconfig -o /boot/grub/grub.cfg

    # APT's VersionedKernelPackages protects versioned kernels from autoremove; purge explicitly
    # Keep only the versioned kernel that the new metapackage depends on
    _keep_kernel="$(apt-cache depends "${_new_kernel_meta_package}" 2>/dev/null | awk '/Depends:.*linux-image-[0-9]/ {print $2}')"
    _old_kernel_packages=( $(
        dpkg -l "${_old_kernel_meta_package}" 2>/dev/null | awk '/^ii/ {print $2}'
        { dpkg -l 'linux-image-[0-9]*' 'linux-modules-[0-9]*' 'linux-modules-extra-[0-9]*' 2>/dev/null || true; } | awk '/^ii/ {print $2}' | grep -v "${_keep_kernel}" || true
        { dpkg -l 'linux-headers-*' 'linux-tools-*' 2>/dev/null || true; } | awk '/^ii/ {print $2}'
    ) )
    test ${#_old_kernel_packages[@]} -gt 0 && apt-get purge -y "${_old_kernel_packages[@]}"
}
_apt_install_packages() {
    # Install required packages
    apt-get install -y --allow-remove-essential -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confnew" "${_required_packages[@]}"
}
_apt_purge_packages() {
    # Build the list of installed packages to keep; nuke everything else
    _keep_packages=("${_required_packages[@]}")
    for pkg in "${_allowed_packages[@]}"; do
        if dpkg-query -W -f='${Status}' "${pkg}" 2> /dev/null | grep -q "install ok installed"; then
            _keep_packages+=("${pkg}")
        fi
    done

    # Mark all as auto (removable), then mark the remaining as manual (keep)
    apt-mark showmanual | xargs -r apt-mark auto > /dev/null 2>&1
    apt-mark manual "${_keep_packages[@]}" > /dev/null 2>&1

    test ${#_purge_packages[@]} -gt 0 && apt-mark auto "${_purge_packages[@]}"
    apt-get autoremove --purge -y -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confnew" -o APT::AutoRemove::RecommendsImportant=false -o APT::AutoRemove::SuggestsImportant=false

    # Purge packages in 'rc' state (removed yet config lingers) so dpkg cleans up statoverrides
    dpkg -l | awk '/^rc/ {print $2}' | xargs -r dpkg --purge
}
_apt_reconfigure() {
    # compatibility with Ubuntu 24.04 (not needed on Ubuntu 25.10 or Debian 13 or later)
    command -v ucf &>/dev/null && ucf --purge /etc/ssh/sshd_config && ucfr --purge openssh-server /etc/ssh/sshd_config

    # Clear debconf database and factory-reset configs modified by cloud providers
    rm -f ${_reconfigure_files[@]} /var/cache/debconf/*.dat

    apt-get install --reinstall -y -o Dpkg::Options::="--force-confmiss" -o Dpkg::Options::="--force-confnew" "${_reconfigure_packages[@]}"
}

_configure_system() {
    # Get rid of garbage in grub file, if any
    test -f /etc/default/grub && sed -i 's/ PACKER_SSHPUBKEY=[^ ]*//' /etc/default/grub

    # Lock root account (no password, no direct login)
    passwd -l root

    # Disable and remove provider-created swap
    swapoff -a 2>/dev/null || true
    sed -i '/swap/d' /etc/fstab

    # Set locale and timezone
    echo 'LANG=en_US.UTF-8'  > /etc/locale.conf
    echo 'en_US.UTF-8 UTF-8' > /etc/locale.gen; locale-gen &>/dev/null || true
    ln -sf /usr/share/zoneinfo/UTC /etc/localtime
    echo "UTC" > /etc/timezone

    # Reset hosts file
    cat > /etc/hosts <<EOF
127.0.0.1   localhost
::1         localhost ip6-localhost ip6-loopback
EOF
}
_prune_users_and_groups() {
    # Remove users and groups now that packages (and their services) are purged
    _remove_users=(debian Debian-exim polkitd systemd-timesync uuidd)
    _remove_users+=($(awk -F: '$3 >= 1000 && $3 < 65534 {print $1}' /etc/passwd))
    _remove_groups=(admin crontab debian Debian-exim docker google-sudoers lxd netdev polkitd systemd-timesync uuidd)
    for _u in "${_remove_users[@]}";  do getent passwd "${_u}" > /dev/null 2>&1 && userdel -f "${_u}" || true; done
    for _g in "${_remove_groups[@]}"; do getent group  "${_g}" > /dev/null 2>&1 && groupdel   "${_g}" || true; done
}

_clean_system_files() {
    find /usr/lib /var -type f -name '*.pyc' -delete # Remove stale Python bytecode
    rm -rf \
        `# identity       ` /etc/{hostname,adjtime,aliases,mailname,cloud-release} \
        `# user backups   ` /etc/{passwd,group,shadow,gshadow,subuid,subgid}- \
        `# crypt tab      ` /etc/crypttab \
        `# users          ` /home \
        `# motd/banners   ` /etc/{motd,update-motd.d/*} /run/motd.dynamic \
        `# cloud-init     ` /etc/{sudoers.d/*,ssh/sshd_config.d/*,skel/.cloud-locale-test.skip,initramfs-tools/conf.d/resume,cloud/clean.d/99-installer} \
        `# dpkg leftovers ` /etc/{dhcpcd.conf.dpkg-dist,default/grub.ucf-dist,.resolv.conf.systemd-resolved.bak,apparmor.d,multipath,pollinate,xml,sgml} /usr/share/dict/common.* /usr/lib/firmware/regulatory.db{,.p7s} /usr/lib/python3/dist-packages/{dbus,gi,pygtkcompat} /var/lib/{dhcp,libuuid} /var/crash /media \
        `# pam            ` /etc/pam.d/*.pam-old \
        `# debconf        ` /var/cache/debconf/*.dat-old \
        `# timesyncd      ` /etc/systemd/{timesyncd.conf,timesyncd.conf.d} /etc/systemd/system/{,*/}{systemd-timesyncd,dbus-org.freedesktop.timesync1}.service /etc/dhcp /var/lib/systemd/{deb-systemd-helper-enabled/*timesync*,deb-systemd-helper-enabled/*time-wait*,deb-systemd-helper-enabled/*/systemd-time*,timesync} /var/lib/dpkg/info/systemd-timesyncd.* \
        `# stale timers   ` /var/lib/systemd/timers/stamp-*.timer \
        `# backups        ` /var/backups/* /var/lib/ucf/{hashfile.*,registry.*} \
        `# root           ` /root/{*,.[!.]*} \
        `# logs and temp  ` /var/{log/*,tmp/*} /tmp/* \
        `# swap           ` /swapfile

    # Ubuntu-specific cleanup
    rm -rf \
        `# ubuntu         ` /etc/apt/preferences.d.save /var/lib/ubuntu-drivers-common \
        `# snap           ` /snap /var/{snap,lib/snapd}
}
_clean_provider_files() {
    rm -rf \
        `# AWS            ` /opt/aws /etc/amazon /var/lib/amazon /usr/share/ec2-instance-connect \
        `# Azure          ` /var/lib/waagent /etc/waagent.conf /{opt,var/opt,etc/opt}/microsoft /opt/omi \
        `# GCP            ` /etc/{default/instance_configs.cfg*,google_instance_id,boto.cfg} /usr/bin/google_* /usr/share/google-guest-agent /var/lib/google* \
        `# IBM Cloud      ` /opt/{IBM,bnpp,BUAgent,draios} \
        `# Oracle Cloud   ` /{opt,etc,usr/libexec}/oracle-cloud* /var/lib/oracle-cloud-agent \
        `# Rackspace      ` /usr/share/nova-agent /etc/rackspace-monitoring-agent \
        `# DigitalOcean   ` /opt/digitalocean /etc/do-agent /etc/systemd/system/{,*/}vpc-peering.service /etc/{ec2_version,overlayroot.local.conf} \
        `# Linode         ` /{opt,etc}/linode /etc/{profile.d/lish.sh,network/.interfaces.linode-*,.resolv.conf.linode-*,kernel-img.conf,kernel/postinst.d/linode} \
        `# Vultr          ` /{opt,etc,var/lib}/vultr /usr/lib/systemd/system/cloud-init-log-reader.service \
        `# Equinix Metal  ` /{opt,etc}/packet \
        `# OVHcloud       ` /{opt,etc}/ovh /usr/bin/{noderig,beamium} /opt/{noderig,beamium} /etc/beamium \
        `# Hetzner        ` /etc/{hc-utils,hetzner-build} \
        `# Ionos          ` /{etc,opt}/ionos \
        `# Scaleway       ` /{etc,opt}/scaleway /usr/local/sbin/scw-* \
        `# Yandex Cloud   ` /{opt,etc}/yandex \
        `# UpCloud        ` /{etc,opt}/upcloud \
        `# Exoscale       ` /{etc,opt}/exoscale \
        `# Leaseweb       ` /opt/leaseweb \
        `# Selectel       ` /opt/selectel \
        `# Gcore          ` /{etc,opt}/gcore \
        `# Civo           ` /{etc,opt}/civo \
        `# Cherry Servers ` /{etc,opt}/cherry \
        `# Alibaba Cloud  ` /usr/local/aegis /usr/sbin/aliyun* /etc/aliyun* /opt/Chinese /usr/local/{cloudmonitor,share/aliyun-assist,share/assist-daemon} \
        `# Huawei Cloud   ` /usr/local/hostguard /opt/huawei \
        `# Tencent Cloud  ` /usr/local/{qcloud,tat-agent,barad,sgagent,YDLive} /var/lib/qcloud \
        `# Baidu Cloud    ` /usr/local/bce /opt/hosteye \
        `# Naver Cloud    ` /opt/{ncloud,nbp}
}
_ssh_access() {
    mkdir -p /root/.ssh/
    echo "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIBZoWV3jeaTVhwJhtXGkpcns8v/NNFvTOfEoUY6EzJ/D jonathan-oliver" > /root/.ssh/authorized_keys
    chmod 0700 /root/.ssh && chmod 0600 /root/.ssh/authorized_keys
}
_upgrade_system() {
    apt-get update -o Acquire::PDiffs=false -o Acquire::Languages=none
    apt-get dist-upgrade       -y -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confnew" -o Dpkg::Options::="--force-confmiss" -o Dpkg::Options::="--force-overwrite"
    apt-get autoremove --purge -y -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confnew" -o Dpkg::Options::="--force-confmiss" -o Dpkg::Options::="--force-overwrite" -o APT::AutoRemove::RecommendsImportant=false -o APT::AutoRemove::SuggestsImportant=false
    apt-get clean -y
}

_main
